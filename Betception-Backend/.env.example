NODE_ENV=production
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=betception_user
DB_PASSWORD=replace-with-your-database-password
DB_NAME=betception

ACCESS_TOKEN_SECRET=replace-with-a-random-string-of-at-least-32-characters
REFRESH_TOKEN_SECRET=replace-with-a-random-string-of-at-least-32-characters
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

FRONTEND_ORIGIN=https://www.example.com
COOKIE_SECURE=true
COOKIE_SAMESITE=strict
TRUST_PROXY=true

NEW_USER_INITIAL_BALANCE=1000

METRICS_ENABLED=false
METRICS_API_KEY=
DOCS_ENABLED=false
DOCS_API_KEY=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
