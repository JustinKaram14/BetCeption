

# ── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ────────────────────────────────────────────────
# When running the backend locally against the Docker DB use:
#   DB_HOST=127.0.0.1  DB_PORT=3307
# Inside Docker Compose the backend container uses DB_HOST=db and DB_PORT=3306.
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=betuser
DB_PASSWORD=betpw
DB_NAME=betception

# ── JWT Secrets (REQUIRED – min. 32 characters each) ────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=replace-me-with-a-random-string-of-at-least-32-chars
REFRESH_TOKEN_SECRET=replace-me-with-another-random-string-of-at-least-32-chars

# ── JWT TTL ──────────────────────────────────────────────────
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:4200

# ── Cookies ──────────────────────────────────────────────────
# Set COOKIE_SECURE=false for local HTTP development (default in dev mode).
# In production this must be true (HTTPS only).
COOKIE_SECURE=false
# strict | lax | none   (none requires COOKIE_SECURE=true)
COOKIE_SAMESITE=strict

# ── Game Settings ─────────────────────────────────────────────
# Starting wallet balance for every newly registered user.
NEW_USER_INITIAL_BALANCE=1000

# ── Proxy ─────────────────────────────────────────────────────
# Set to true / a number / a CIDR string when behind a reverse proxy.
# TRUST_PROXY=false

# ── Observability ─────────────────────────────────────────────
# Both surfaces are enabled in development by default.
# In production set to true and supply an API key.
METRICS_ENABLED=true
# METRICS_API_KEY=your-metrics-api-key

DOCS_ENABLED=true
# DOCS_API_KEY=your-swagger-api-key

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
